{
	"name": "@neovici/cosmoz-omnitable-treenode-column",
	"version": "11.1.0",
	"description": "A column for cosmoz-omnitable that displays a tree node.",
	"keywords": [
		"polymer",
		"web-components"
	],
	"homepage": "https://github.com/Neovici/cosmoz-omnitable-treenode-column#readme",
	"bugs": {
		"url": "https://github.com/Neovici/cosmoz-omnitable-treenode-column/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neovici/cosmoz-omnitable-treenode-column.git"
	},
	"license": "Apache-2.0",
	"author": "",
	"main": "cosmoz-omnitable-treenode-column.js",
	"directories": {
		"test": "test"
	},
	"scripts": {
		"lint": "eslint --cache .",
		"check:duplicates": "check-duplicate-components",
		"start": "npm run storybook",
		"test": "wtr --coverage",
		"test:watch": "wtr --watch",
		"storybook:start": "storybook dev -p 8000",
		"storybook:build": "storybook build",
		"storybook:deploy": "storybook-to-ghpages",
		"storybook:preview": "npm run storybook:build && http-server ./storybook-static/ --silent"
	},
	"release": {
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			"@semantic-release/github",
			"@semantic-release/npm",
			"@semantic-release/git"
		],
		"branch": "master",
		"preset": "conventionalcommits"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"*.js"
	],
	"dependencies": {
		"@neovici/cosmoz-autocomplete": "^13.6.0-beta.1",
		"@neovici/cosmoz-omnitable": "^18.4.0-beta.1",
		"@neovici/cosmoz-tokens": "^3.4.0",
		"@neovici/cosmoz-tree": "^3.0.0",
		"@neovici/cosmoz-treenode": "^6.0.0",
		"@neovici/cosmoz-utils": "^6.0.0",
		"@pionjs/pion": "^2.13.0",
		"@polymer/paper-spinner": "^3.0.0",
		"@polymer/polymer": "^3.4.1",
		"i18next": "^23.16.8",
		"lit-html": "^3.3.2",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.2",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@neovici/cfg": "^2.8.0",
		"@open-wc/testing": "^4.0.0",
		"@semantic-release/changelog": "^6.0.0",
		"@semantic-release/git": "^10.0.0",
		"@storybook/addon-a11y": "^10.3.6",
		"@storybook/addon-docs": "^10.3.6",
		"@storybook/addon-vitest": "^10.3.6",
		"@storybook/storybook-deployer": "^2.8.7",
		"@storybook/web-components-vite": "^10.3.6",
		"@typescript-eslint/eslint-plugin": "^8.5.0",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint-plugin-storybook": "^10.3.6",
		"husky": "^9.0.0",
		"lint-staged": "^16.2.7",
		"playwright": "^1.59.1",
		"semantic-release": "^25.0.1",
		"sinon": "^21.0.0",
		"storybook": "^10.3.6",
		"typescript-eslint": "^8.48.0",
		"vitest": "^4.1.5"
	},
	"overrides": {
		"conventional-changelog-conventionalcommits": ">= 8.0.0"
	}
}
